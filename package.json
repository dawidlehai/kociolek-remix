{
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "npm run sass:build && remix vite:build",
    "dev": "concurrently \"npm run sass\" \"remix vite:dev\"",
    "sass": "sass --watch --style=compressed app/main.scss:app/main.css app/styles/home.scss:app/styles/home.css app/styles/menu-page.scss:app/styles/menu-page.css",
    "sass:build": "sass --style=compressed app/main.scss:app/main.css app/styles/home.scss:app/styles/home.css app/styles/menu-page.scss:app/styles/menu-page.css",
    "start": "cross-env NODE_ENV=production netlify dev",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.2",
    "@netlify/remix-adapter": "^3.0.0",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "phosphor-react": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@netlify/remix-adapter": "^3.0.0",
    "@remix-run/dev": "^2.17.4",
    "@remix-run/eslint-config": "^2.17.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-transition-group": "^4.4.5",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^6.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
